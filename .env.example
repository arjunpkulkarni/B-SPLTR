# ── Database (Docker Compose overrides with `db` hostname) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wealthsplit

# ── Supabase Auth ──
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
# Optional: only if JWT `iss` does not match {SUPABASE_URL}/auth/v1
SUPABASE_JWT_ISSUER=

# ── Groq (receipt AI) ──
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RECEIPT_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_RECEIPT_CLEANUP_MODEL=openai/gpt-oss-20b

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Misc ──
UPLOAD_DIR=./uploads
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
